# Secure File Transfer — Relay Server Configuration
# Скопіюйте цей файл як .env та налаштуйте значення.

# --- Сервер ---
SFT_HOST=0.0.0.0
SFT_PORT=8000
SFT_DEBUG=false
SFT_LOG_LEVEL=INFO

# --- Сесії ---
SFT_SESSION_TTL_SECONDS=1800
SFT_SESSION_TTL_WAITING=600
SFT_MAX_SESSIONS=1000

# --- Передача файлів ---
SFT_MAX_FILE_SIZE_BYTES=104857600
SFT_MAX_CHUNK_SIZE_BYTES=358400

# --- Rate Limiting ---
SFT_HTTP_RATE_LIMIT=10
SFT_WS_CONNECT_RATE_LIMIT=5

# --- CORS ---
# Для production — вкажіть конкретний домен:
# SFT_CORS_ORIGINS=["https://yourdomain.com"]
SFT_CORS_ORIGINS=["*"]
