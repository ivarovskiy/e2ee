{
  "name": "secure-file-transfer",
  "version": "1.0.0",
  "description": "Система захищеного обміну файлами з E2EE та QR-верифікацією",
  "author": "Приймаченко В.В.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "server": "cd server && uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
    "android:init": "npx cap add android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "npx cap sync android && cd android && ./gradlew assembleDebug",
    "android:run": "npx cap run android",
    "ios:init": "npx cap add ios",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/camera": "^6.1.0",
    "@capacitor/core": "^6.2.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}
